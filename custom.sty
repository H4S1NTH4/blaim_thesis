%% ============================================================
%%  custom.sty  –  SLIIT Dissertation Style Package
%%  Compiler: XeLaTeX
%% ============================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{custom}[2025/08/01 SLIIT Dissertation Style]

%% ── PAGE GEOMETRY ───────────────────────────────────────────
\RequirePackage[
  a4paper,
  top    = 25mm,
  bottom = 40mm,
  left   = 40mm,
  right  = 25mm
]{geometry}

%% ── FONTS (XeLaTeX) ─────────────────────────────────────────
\RequirePackage{fontspec}
\setmainfont{Times New Roman}

%% ── LINE SPACING ─────────────────────────────────────────────
\RequirePackage{setspace}
\setstretch{1.5}              % 1.5 throughout body

%% ── MICRO-TYPOGRAPHY ─────────────────────────────────────────
\RequirePackage{microtype}

%% ── MATHS ────────────────────────────────────────────────────
\RequirePackage{amsmath, amssymb}

%% ── GRAPHICS & FIGURES ───────────────────────────────────────
\RequirePackage{graphicx}
\RequirePackage{float}         % [H] placement
\graphicspath{{figures/}}      % put images in /figures folder

%% ── TABLES ───────────────────────────────────────────────────
\RequirePackage{booktabs}
\RequirePackage{tabularx}
\RequirePackage{array}

%% ── CAPTIONS ─────────────────────────────────────────────────
\RequirePackage[
  font     = singlespacing,    % single-space captions per guidelines
  labelfont= bf,
  skip     = 6pt
]{caption}

%% ── FIGURE / TABLE NUMBERING  (Chapter.Number) ───────────────
\RequirePackage{chngcntr}
\counterwithin{figure}{chapter}
\counterwithin{table}{chapter}

%% ── COLOURS ──────────────────────────────────────────────────
\RequirePackage[dvipsnames]{xcolor}

%% ── HYPERLINKS ───────────────────────────────────────────────
\RequirePackage[
  colorlinks = true,
  linkcolor  = black,
  citecolor  = black,
  urlcolor   = blue,
  bookmarks  = true
]{hyperref}

%% ── BIBLIOGRAPHY ─────────────────────────────────────────────
\RequirePackage{natbib}        % works with apalike & unsrtnat

%% ── ACRONYMS / ABBREVIATIONS ─────────────────────────────────
\RequirePackage[printonlyused, withpage]{acronym}

%% ── HEADER / FOOTER ──────────────────────────────────────────
\RequirePackage{fancyhdr}

%% Plain style – used for chapter opening pages
\fancypagestyle{plain}{%
  \fancyhf{}
  \renewcommand{\headrulewidth}{0pt}
  \fancyfoot[C]{\thepage}       % centred (front matter)
}

%% mainmatter style – Arabic, bottom right
\fancypagestyle{mainpages}{%
  \fancyhf{}
  \renewcommand{\headrulewidth}{0pt}
  \fancyfoot[R]{\thepage}
}

%% ── CHAPTER / SECTION HEADING STYLES ─────────────────────────
\RequirePackage{titlesec}

% Chapter: Numbered, ALL CAPS, Bold, 14 pt, left-aligned
\titleformat{\chapter}[block]
  {\normalfont\fontsize{14}{17}\bfseries\raggedright}
  {\thechapter.}                % "1." prefix
  {0.5em}                       % space between number and title
  {\MakeUppercase}              % apply ALL CAPS to title text
\titlespacing{\chapter}{0pt}{-20pt}{20pt}

% Section: Title Case, Bold, 12 pt
\titleformat{\section}
  {\normalfont\fontsize{12}{15}\bfseries}
  {\thesection}
  {1em}{}
\titlespacing{\section}{0pt}{12pt}{6pt}

% Subsection: Sentence case, Bold, 12 pt
\titleformat{\subsection}
  {\normalfont\fontsize{12}{15}\bfseries}
  {\thesubsection}
  {1em}{}
\titlespacing{\subsection}{0pt}{10pt}{4pt}

%% ── MAINMATTER COMMAND OVERRIDE ──────────────────────────────
%% Switch page style and numbering when main text begins
\let\old@mainmatter\mainmatter
\renewcommand{\mainmatter}{%
  \old@mainmatter
  \pagestyle{mainpages}
  \pagenumbering{arabic}
  \setcounter{page}{1}
}

%% ── MISCELLANEOUS ────────────────────────────────────────────
\RequirePackage{parskip}        % space between paragraphs
\setlength{\parindent}{0pt}
\setlength{\parskip}{6pt}

\RequirePackage{lipsum}         % for placeholder text (remove in final)

\endinput
